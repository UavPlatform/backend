TZ=Asia/Shanghai

APP_PORT=8081

BACKEND_IMAGE=ghcr.io/uavplatform/backend
BACKEND_IMAGE_TAG=latest

MYSQL_DATABASE=drone_db
MYSQL_USER=drone
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_password

JWT_SECRET=replace-with-a-strong-secret-at-least-32-chars
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m
WATCHTOWER_POLL_INTERVAL=300
WATCHTOWER_DOCKER_API_VERSION=1.44
DOCKER_CONFIG_FILE=/home/fuwaki/.docker/config.json
